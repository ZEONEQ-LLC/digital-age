# Supabase — public client
# Werte aus Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# WICHTIG: Service-Role-Keys NIEMALS client-seitig (kein NEXT_PUBLIC_-Prefix).
# Falls server-side benötigt: separat in Vercel Env als SUPABASE_SERVICE_ROLE_KEY,
# nie ins Repo committen.

# Supabase Project Ref (für CLI-Befehle wie `gen types`, nicht client-seitig)
SUPABASE_PROJECT_REF=your-project-ref

# Newsletter — Server-Salt für IP-Hashing (32-byte hex, z.B. `openssl rand -hex 32`)
# Wird nur server-seitig in der subscribeToNewsletter-Server-Action verwendet.
# Niemals client-seitig, niemals ins Repo committen.
NEWSLETTER_IP_HASH_SALT=your-32-byte-hex-secret
